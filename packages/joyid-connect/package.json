{
  "name": "@byterent/joyid-connect",
  "version": "0.2.0",
  "description": "CCC Signer + React provider + QR modal for the JoyID redirect-relay flow",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@ckb-ccc/ccc": "^1.0.0",
    "@joyid/common": "^0.2.0",
    "qr-code-styling": "^1.9.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "qr-code-styling": { "optional": true }
  },
  "devDependencies": {
    "@ckb-ccc/ccc": "^1.0.0",
    "@joyid/common": "^0.2.0",
    "@types/react": "^19.0.0",
    "qr-code-styling": "^1.9.0",
    "react": "^19.0.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "ckb",
    "nervos",
    "joyid",
    "ccc",
    "wallet",
    "connector",
    "webauthn",
    "passkey",
    "mobile"
  ],
  "license": "MIT",
  "sideEffects": false
}
